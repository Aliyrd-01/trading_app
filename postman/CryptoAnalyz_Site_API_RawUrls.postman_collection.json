                  "pm.test('If 200 then has enabled', function () { if (pm.response.code !== 200) return; const j = pm.response.json(); pm.expect(j).to.have.property('enabled'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auto_signals/status",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Cookie", "value": "{{siteCookie}}"}
            ],
            "url": "{{siteBaseUrl}}/auto_signals/status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 401', function () { pm.expect([200,401]).to.include(pm.response.code); });",
                  "pm.test('Response time < 5000ms', function () { pm.expect(pm.response.responseTime).to.be.below(5000); });",
                  "pm.test('If 200 then has next_check', function () { if (pm.response.code !== 200) return; const j = pm.response.json(); pm.expect(j).to.have.property('next_check'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auto_signals/test",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Cookie", "value": "{{siteCookie}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"language\": \"{{language}}\"\n}"},
            "url": "{{siteBaseUrl}}/auto_signals/test"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 401', function () { pm.expect([200,401]).to.include(pm.response.code); });",
                  "pm.test('Response time < 5000ms', function () { pm.expect(pm.response.responseTime).to.be.below(5000); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auto_signals/logs?limit=20",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Cookie", "value": "{{siteCookie}}"}
            ],
            "url": "{{siteBaseUrl}}/auto_signals/logs?limit=20"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 401', function () { pm.expect([200,401]).to.include(pm.response.code); });",
                  "pm.test('Response time < 5000ms', function () { pm.expect(pm.response.responseTime).to.be.below(5000); });",
                  "pm.test('If 200 then response is array', function () { if (pm.response.code !== 200) return; const j = pm.response.json(); pm.expect(Array.isArray(j)).to.equal(true); });"
                ]
              }
            }
          ]
        }
      ]
    },
