  "item": [
    {
      "name": "Laravel Site API ({{siteBaseUrl}})",
      "item": [
        {
          "name": "Health - GET /test",
          "request": {
            "method": "GET",
            "url": {"raw": "{{siteBaseUrl}}/test", "host": ["{{siteBaseUrl}}"], "path": ["test"]}
          }
        },
        {
          "name": "Webhook - TradingView - POST /webhook/tradingview",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secret\": \"{{webhookSecret}}\",\n  \"email\": \"{{email}}\",\n  \"symbol\": \"BTC/USDT\",\n  \"action\": \"BUY\",\n  \"entry_price\": 43000,\n  \"stop_loss\": 42500,\n  \"take_profit\": 44000,\n  \"timeframe\": \"15m\",\n  \"language\": \"{{language}}\",\n  \"comment\": \"manual test\"\n}"
            },
            "url": {"raw": "{{siteBaseUrl}}/webhook/tradingview", "host": ["{{siteBaseUrl}}"], "path": ["webhook", "tradingview"]}
          }
        },
        {
          "name": "Scheduler - GET /scheduler/run?key=...",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{siteBaseUrl}}/scheduler/run?key={{schedulerKey}}",
              "host": ["{{siteBaseUrl}}"],
              "path": ["scheduler", "run"],
              "query": [{"key": "key", "value": "{{schedulerKey}}"}]
            }
          }
        },
        {
          "name": "Auth",
          "item": [
            {
              "name": "POST /auth/register",
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"name\": \"{{name}}\"\n}"
                },
                "url": {"raw": "{{siteBaseUrl}}/auth/register", "host": ["{{siteBaseUrl}}"], "path": ["auth", "register"]}
              }
            },
            {
              "name": "POST /auth/login",
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
                },
                "url": {"raw": "{{siteBaseUrl}}/auth/login", "host": ["{{siteBaseUrl}}"], "path": ["auth", "login"]}
              }
            },
            {
              "name": "POST /auth/token (saves {{laravelToken}})",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "try {",
                      "  const j = pm.response.json();",
                      "  if (j && j.token) {",
                      "    pm.collectionVariables.set('laravelToken', j.token);",
                      "  }",
                      "} catch (e) {}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
                },
                "url": {"raw": "{{siteBaseUrl}}/auth/token", "host": ["{{siteBaseUrl}}"], "path": ["auth", "token"]}
              }
            },
            {
              "name": "POST /auth/logout",
              "request": {"method": "POST", "url": {"raw": "{{siteBaseUrl}}/auth/logout", "host": ["{{siteBaseUrl}}"], "path": ["auth", "logout"]}}
            },
            {
              "name": "GET /auth/me",
              "request": {"method": "GET", "url": {"raw": "{{siteBaseUrl}}/auth/me", "host": ["{{siteBaseUrl}}"], "path": ["auth", "me"]}}
            },
