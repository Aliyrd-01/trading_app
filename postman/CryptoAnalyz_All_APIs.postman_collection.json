              "name": "DELETE /auth/account",
              "request": {
                "method": "DELETE",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {"mode": "raw", "raw": "{\n  \"password\": \"{{password}}\"\n}"},
                "url": {"raw": "{{siteBaseUrl}}/auth/account", "host": ["{{siteBaseUrl}}"], "path": ["auth", "account"]}
              }
            },
            {
              "name": "POST /auth/verify-email",
              "request": {
                "method": "POST",
