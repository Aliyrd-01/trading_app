              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {"mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}"},
                "url": {"raw": "{{siteBaseUrl}}/auth/reset-password-request", "host": ["{{siteBaseUrl}}"], "path": ["auth", "reset-password-request"]}
              }
            },
            {
              "name": "POST /auth/reset-password",
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {"mode": "raw", "raw": "{\n  \"token\": \"\",\n  \"password\": \"{{password}}\"\n}"},
                "url": {"raw": "{{siteBaseUrl}}/auth/reset-password", "host": ["{{siteBaseUrl}}"], "path": ["auth", "reset-password"]}
              }
            }
          ]
